# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Notebook and interactive caches
.ipynb_checkpoints/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Type checker and linter caches
.mypy_cache/
.ruff_cache/
.pyre/

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs and runtime files
*.log
*.out
*.err

# Local environment and secrets
.env
.env.*

# ML training outputs generated by scripts in backup/
chunks/
pretrained/
finetuned/
moldeberta-tokenizer/
**/checkpoint*/

# Common model/data artifacts generated during experiments
*.ckpt
*.pt
*.pth
*.bin
*.h5
*.onnx
*.npz
*.tmp

# Experiment tracking
runs/
wandb/
mlruns/

# Project output directory (plots/embeddings and other generated results)
output/

# Large model artifacts
model/

# Ignore CSV datasets in data but keep folder marker
data/**/*.csv
data/*.csv
!data/.gitkeep